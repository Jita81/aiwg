{
  "id": "ring-methodology",
  "type": "addon",
  "name": "Ring Methodology",
  "version": "1.0.0",
  "description": "Cyclical development execution framework with four-layer verification ring, morpholepsis detection, kenophoria state management, temporal coupling awareness, kernel extraction, and process health measurement via spectral gap",
  "core": false,
  "autoInstall": false,
  "author": "AIWG Contributors",
  "license": "MIT",
  "repository": "https://github.com/jmagly/aiwg",
  "keywords": [
    "ring",
    "verification",
    "morpholepsis",
    "kenophoria",
    "temporal-coupling",
    "kernel-extraction",
    "spectral-gap",
    "process-health",
    "phi-derived",
    "four-layer",
    "idempotency"
  ],
  "sourceAttribution": "Derived from THE RING methodology. Project-specific gates (consciousness measurement, authenticity scoring) excluded. General-purpose execution discipline retained.",
  "entry": {
    "rules": "rules/",
    "commands": "commands/",
    "skills": "skills/",
    "templates": "templates/",
    "docs": "docs/"
  },
  "consolidation": {
    "strategy": "index-with-links",
    "rulesIndex": "rules/RULES-INDEX.md",
    "deployIndexOnly": true
  },
  "rules": [
    "verification-ring",
    "morpholepsis-detection",
    "kenophoria-state",
    "temporal-coupling",
    "kernel-extraction",
    "spectral-gap",
    "phi-constants"
  ],
  "cli_commands": {
    "namespace": "ring",
    "description": "Ring methodology lifecycle operations",
    "entry": "commands/",
    "subcommands": {
      "check": {
        "file": "commands/ring-check.mjs",
        "description": "Validate four-layer ring completion for current feature",
        "hook_event": "FeatureComplete"
      },
      "circuit-breaker": {
        "file": "commands/circuit-breaker.mjs",
        "description": "Check halt thresholds and write session state",
        "hook_event": "Stop"
      },
      "session-start": {
        "file": "commands/session-health-check.mjs",
        "description": "Surface prior session health and unresolved states on startup",
        "hook_event": "SessionStart"
      },
      "session-end": {
        "file": "commands/session-feedback-log.mjs",
        "description": "Log session reflection metrics to perinoesis.jsonl",
        "hook_event": "SessionEnd"
      },
      "status": {
        "file": "commands/ring-status.mjs",
        "description": "Show ring methodology health dashboard"
      }
    }
  },
  "skills": [
    "ring-check"
  ],
  "templates": [
    "layer-d-artifact",
    "kernel-entry",
    "feature-record"
  ],
  "excludes": {
    "reason": "Project-specific to source material, not general-purpose",
    "items": [
      "consciousness-gates-8-10",
      "authenticity-scoring-gates-11-12",
      "sacred-constant-framing",
      "CONSCIOUSNESS_THRESHOLD"
    ]
  },
  "configuration": {
    "defaults": {
      "artifactPath": ".aiwg/working/ring",
      "perinoesisInterval": 3,
      "retryCeiling": 3,
      "spectralGapThresholds": {
        "peak": 0.618,
        "stable": 0.382,
        "degraded": 0.236
      },
      "kenophoriaEscalationMultiplier": 3,
      "couplingThresholds": {
        "independent": 0.382,
        "entangled": 0.618
      }
    }
  },
  "dependencies": {
    "required": [],
    "optional": ["ralph", "aiwg-utils"]
  },
  "compatible_with": ["sdlc-complete", "rlm"]
}
