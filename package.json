{
  "name": "aiwg",
  "version": "2026.4.0-rc.19",
  "description": "Deployment tool and support utility for AI context. Copies agents, skills, commands, rules, and behaviors into the paths each AI platform reads (Claude Code, Codex, Copilot, Cursor, Warp, OpenClaw, and 4 more) so one source of truth works across 10 platforms. Optional utilities for persistent artifact memory, background orchestration, autonomous loops, and artifact indexing.",
  "type": "module",
  "bin": {
    "aiwg": "bin/aiwg.mjs"
  },
  "man": "./man/aiwg.1",
  "main": "src/cli/index.mjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "node ./bin/postinstall.mjs",
    "docs:collect": "node tools/manifest/collect-component-docs.mjs",
    "docs:collect:dry": "node tools/manifest/collect-component-docs.mjs --dry-run",
    "validate-metadata": "node tools/cli/validate-metadata.mjs",
    "package-plugins": "node tools/plugin/package-plugins.mjs --all",
    "package-plugins:clean": "node tools/plugin/package-plugins.mjs --all --clean",
    "build": "tsc",
    "test": "vitest run",
    "test:ci": "vitest run && vitest run --config vitest.uat.config.js",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "uat": "vitest run --config vitest.uat.config.js",
    "uat:watch": "vitest --config vitest.uat.config.js",
    "uat:live": "vitest run --config vitest.uat-live.config.js",
    "uat:claude": "vitest run --config vitest.uat-live.config.js --reporter=verbose ralph-live-claude",
    "uat:codex": "vitest run --config vitest.uat-live.config.js --reporter=verbose ralph-live-codex",
    "uat:opencode": "vitest run --config vitest.uat-live.config.js --reporter=verbose ralph-live-opencode",
    "uat:factory": "vitest run --config vitest.uat-live.config.js --reporter=verbose ralph-live-factory",
    "uat:daemon": "vitest run --config vitest.uat-daemon.config.js",
    "uat:daemon:claude": "vitest run --config vitest.uat-daemon.config.js --reporter=verbose daemon-live-claude"
  },
  "files": [
    "bin/",
    "src/",
    "tools/",
    "agentic/",
    "docs/",
    "templates/",
    "plugins/",
    "man/",
